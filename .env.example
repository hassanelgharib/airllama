# Server Configuration
HOST=0.0.0.0
PORT=11434

# Model Configuration
MODEL_CACHE_DIR=~/.cache/airllm
# DEFAULT_COMPRESSION: leave empty for CPU-only, or set to 4bit / 8bit (requires CUDA + bitsandbytes)
DEFAULT_COMPRESSION=
MAX_LOADED_MODELS=1

# HuggingFace Configuration
# Optional: required for gated/private models (e.g. Llama 3)
HF_TOKEN=

# Performance
DEFAULT_MAX_LENGTH=2048
DEFAULT_MAX_NEW_TOKENS=512
